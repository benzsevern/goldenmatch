# GoldenMatch Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   source .env

# ── GPU Routing (choose one) ──────────────────────────────────────

# Option 1: Vertex AI (recommended — no GPU needed, best results)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json  # optional if using gcloud auth
# GOOGLE_CLOUD_LOCATION=us-central1                            # optional, default: us-central1
# VERTEX_EMBEDDING_MODEL=text-embedding-004                    # optional, default: text-embedding-004

# Option 2: Remote GPU endpoint (self-hosted or Colab)
# GOLDENMATCH_GPU_ENDPOINT=http://your-gpu-server:8090

# Option 3: Force a specific mode
# GOLDENMATCH_GPU_MODE=vertex    # vertex | remote | local | cpu_safe

# ── LLM Boost (optional — for --llm-boost flag) ──────────────────

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Database Sync (optional — for goldenmatch sync) ───────────────

# GOLDENMATCH_DATABASE_URL=postgresql://user:pass@localhost:5432/mydb
